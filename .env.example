# Firebase 설정값 — 안내서 3단계에서 Firebase 콘솔의 값으로 채워주세요.
# 이 파일을 복사해 .env 파일을 만들고 값을 넣으면 로컬에서 테스트할 수 있어요.
# Vercel에 올릴 때는 같은 키들을 Vercel 환경변수에 등록합니다.

VITE_FB_API_KEY=여기에_apiKey
VITE_FB_AUTH_DOMAIN=여기에_authDomain
VITE_FB_PROJECT_ID=여기에_projectId
VITE_FB_STORAGE_BUCKET=여기에_storageBucket
VITE_FB_SENDER_ID=여기에_messagingSenderId
VITE_FB_APP_ID=여기에_appId
